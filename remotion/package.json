{
  "name": "makes-video",
  "version": "1.0.0",
  "private": true,
  "description": "Promo video for Makes, built with Remotion. Isolated from the Next app.",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render MakesPromo out/makes-promo.mp4",
    "render:vo": "remotion render MakesPromoVoiceover out/makes-promo-voiceover.mp4",
    "render:web": "npm run render:web:jobpost && npm run render:web:ai && npm run render:web:pipeline",
    "render:web:jobpost": "remotion render Feature-JobPost ../public/video/job-post.mp4 --scale=0.6 --crf=30 --muted",
    "render:web:ai": "remotion render Feature-AiEvaluation ../public/video/ai-evaluation.mp4 --scale=0.6 --crf=30 --muted",
    "render:web:pipeline": "remotion render Feature-PipelineToInbox ../public/video/pipeline-inbox.mp4 --scale=0.6 --crf=30 --muted",
    "voiceover": "node scripts/generate-vo.mjs",
    "still": "remotion still"
  },
  "dependencies": {
    "@remotion/google-fonts": "4.0.409",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.409"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.409",
    "@types/react": "19.0.0",
    "typescript": "5.6.3"
  }
}
